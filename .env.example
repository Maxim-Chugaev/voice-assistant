# Ключ OpenAI (обязательно)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Picovoice AccessKey (обязательно для wake-word)
# Получить: https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=your-picovoice-access-key

# Встроенное wake-word (по умолчанию: jarvis)
# Важно: используется ТОЛЬКО одно слово (без перебора кандидатов).
# PORCUPINE_BUILTIN_KEYWORD=jarvis

# Опционально: путь к кастомному .ppn (имеет приоритет над builtin)
# PORCUPINE_KEYWORD_PATH=/absolute/path/to/keyword.ppn

# Сколько миллисекунд после wake-word отправлять речь в OpenAI
# WAKE_WINDOW_MS=8000

# Закрыть окно, если нет речи столько миллисекунд
# GATE_SILENCE_MS=1200

# Порог RMS для простой локальной VAD
# MIN_RMS=200

# Антидребезг wake-word (повторные срабатывания подряд)
# WAKE_DEBOUNCE_MS=1500

# Linux (ALSA/arecord): опционально выбрать устройство записи
# Посмотреть список: arecord -l
# Пример: AUDIO_DEVICE=plughw:1,0
# AUDIO_DEVICE=

# Устройство воспроизведения (Linux: чтобы звук шёл в нужные колонки, а не в Bluetooth)
# Linux: target для pw-play (имя или id узла). Список: wpctl status  или  pw-cli list-objects Node
# В wpctl status — раздел Audio → Sinks, взять id или имя. Пример: AUDIO_OUTPUT_DEVICE=42  или  alsa_output.usb-...
# macOS: не задавать
# AUDIO_OUTPUT_DEVICE=
