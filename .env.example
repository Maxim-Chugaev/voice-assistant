# Ключ OpenAI (обязательно)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Модель ChatGPT (по желанию)
OPENAI_MODEL=gpt-4o-mini

# Подсказка для Whisper: контекст и частые слова улучшают распознавание (до ~224 токенов).
# OPENAI_WHISPER_PROMPT=Голосовой помощник. Русская речь: альтрон, рецепт, блины, расскажи, погода.
# Модель OpenAI для распознавания речи: whisper-1 (по умолчанию) или gpt-4o-transcribe, если доступна.
# OPENAI_WHISPER_MODEL=whisper-1

# TTS: модель и голос OpenAI.
# Модель: tts-1 (быстрее, дешевле) или tts-1-hd (выше качество).
# Голоса: alloy, echo, fable, onyx (мужской), nova (женский, по умолчанию), shimmer.
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=nova

# Wake word (по умолчанию: альтрон)
# WAKE_WORD=альтрон
# Длина записи фразы после wake word, сек (4–12, по умолчанию 6).
# WAKE_WORD_PHRASE_SECONDS=6

# Порог VAD (Voice Activity Detection): RMS энергия аудио.
# Тишина ~0–200, речь ~500–5000+. Whisper вызывается только когда выше порога.
# Меньше = чувствительнее (больше запросов), больше = только громкая речь.
# VAD_THRESHOLD=300
