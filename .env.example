# Ключ OpenAI (обязательно)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Модель ChatGPT (по желанию)
OPENAI_MODEL=gpt-4o-mini

# Wake word для режима 3 (по умолчанию: альтрон)
WAKE_WORD=альтрон

# Путь к модели Vosk для детекции wake word (режим 3). Если задан — чанки проверяются через Vosk вместо Whisper.
# Скачать русскую модель: https://alphacephei.com/vosk/models (например vosk-model-small-ru-0.22)
# Распаковать и указать путь к папке модели:
VOSK_MODEL_PATH=/path/to/vosk-model-small-ru-0.22
