# OpenAI API key (required)
# Get it here: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Picovoice AccessKey (required for wake word)
# Get it here: https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=your-picovoice-access-key

# Built‑in wake word (default: jarvis)
# Important: ONLY a single keyword is used (no multi‑keyword logic).
# PORCUPINE_BUILTIN_KEYWORD=jarvis

# Optional: path to custom .ppn (takes precedence over builtin)
# PORCUPINE_KEYWORD_PATH=/absolute/path/to/keyword.ppn

# How many milliseconds after wake word to stream mic audio to OpenAI
# WAKE_WINDOW_MS=8000

# Close the gate window if there is no speech for this many ms
# GATE_SILENCE_MS=1200

# RMS threshold for simple local VAD
# MIN_RMS=200

# Wake‑word debounce (block repeated triggers within this many ms)
# WAKE_DEBOUNCE_MS=1500

# Linux (ALSA/arecord): optional input device selection
# List devices: arecord -l
# Example: AUDIO_DEVICE=plughw:1,0
# AUDIO_DEVICE=

# Output device (Linux: force audio to specific speakers instead of Bluetooth)
# Linux: target for pw-play (node id or name). List: wpctl status  or  pw-cli list-objects Node
# In wpctl status use Audio → Sinks id or name. Example: AUDIO_OUTPUT_DEVICE=42  or  alsa_output.usb-...
# macOS: leave unset
# AUDIO_OUTPUT_DEVICE=
